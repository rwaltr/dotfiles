#!/usr/bin/env bash
# auto-bisync — inotify-driven continuous bisync between a local path and an rclone remote
#
# Usage:
#   auto-bisync <local-path> <remote>                  # watch continuously
#   auto-bisync <local-path> <remote> once             # single bisync run then exit
#   auto-bisync <local-path> <remote> resync           # force --resync (first-time / recovery)
#
# Examples:
#   auto-bisync ~/Documents :sftp,host=mouse:Documents
#   auto-bisync ~/Documents :sftp,host=mouse:Documents resync
#
# Requirements: rclone, inotify-tools
# SSH auth via system SSH agent
# Backup dirs: ~/.local/share/bisync-backups/<local-path-slug>/{local,remote}

set -euo pipefail

# ── Args ──────────────────────────────────────────────────────────────────────
if [[ $# -lt 2 ]]; then
    echo "Usage: $(basename "$0") <local-path> <remote> [watch|once|resync]"
    exit 1
fi

LOCAL="$(realpath "$1")"
REMOTE="$2"
CMD="${3:-watch}"

# ── Config ────────────────────────────────────────────────────────────────────
# Backup dirs must be outside the sync source and on the same remote as their respective path
_SAFE_NAME="$(echo "$LOCAL" | tr '/' '_' | sed 's/^_//')"
BACKUP_LOCAL="${HOME}/.local/share/bisync-backups/${_SAFE_NAME}"
# Remote backup: same connection string, sibling of the remote sync path
# e.g. :sftp,host=mouse,key_file=...:/var/tank/home/rwaltr/Documents
#   → :sftp,host=mouse,key_file=...:/var/tank/home/rwaltr/.bisync-backups/home_rwaltr_Documents
# Keeping the backup under the same parent dir ensures it's on the same filesystem,
# so rclone can use a server-side rename instead of a cross-fs copy (SFTP SSH_FX_FAILURE).
_REMOTE_CONN="${REMOTE%:*}:"            # connection prefix up to and including the last colon
_REMOTE_PATH="${REMOTE##*:}"            # path component after the last colon
_REMOTE_PARENT="$(dirname "$_REMOTE_PATH")"  # parent dir of the sync path
BACKUP_REMOTE="${_REMOTE_CONN}${_REMOTE_PARENT}/.bisync-backups/${_SAFE_NAME}"

WATCH_EVENTS="modify,delete,create,move"
SYNC_DELAY=5        # seconds to wait after a change before syncing (debounce)
SYNC_INTERVAL=3600  # seconds between forced syncs even with no changes

# ── Helpers ───────────────────────────────────────────────────────────────────
log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"; }

ICON="${HOME}/.local/share/icons/rwaltr-seal.svg"
EXPIRE_OK=10000    # good notifications expire after 10s (milliseconds)

notify() {
    local level="$1" msg="$2"
    if command -v notify-send &>/dev/null && [[ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ]]; then
        local args=("--icon=$ICON")
        case "$level" in
            ok)   args+=("--expire-time=$EXPIRE_OK" "--urgency=low") ;;
            fail) args+=("--urgency=critical") ;;  # no expiry — stays until dismissed
        esac
        notify-send "auto-bisync" "$msg" "${args[@]}" 2>/dev/null || true
    fi
}

bisync() {
    local extra_flags=("$@")
    log "Running bisync: $LOCAL ↔ $REMOTE"
    rclone bisync \
        "$LOCAL" "$REMOTE" \
        --create-empty-src-dirs \
        --backup-dir1 "$BACKUP_LOCAL" \
        --backup-dir2 "$BACKUP_REMOTE" \
        --compare size,modtime \
        --resilient \
        --verbose \
        "${extra_flags[@]}"
}

# ── Commands ──────────────────────────────────────────────────────────────────
case "$CMD" in
resync)
    log "Running initial resync..."
    bisync --resync
    log "Resync complete"
    ;;

once)
    bisync
    log "Sync complete"
    ;;

watch)
    log "Starting continuous sync: $LOCAL ↔ $REMOTE"
    log "Watching for changes (debounce: ${SYNC_DELAY}s, forced interval: ${SYNC_INTERVAL}s)"

    # Initial sync on startup
    bisync && notify ok "Started ($LOCAL)" || { notify fail "Startup sync failed ($LOCAL)"; log "Startup sync failed"; }

    while true; do
        if inotifywait \
            --recursive \
            --timeout "$SYNC_INTERVAL" \
            --event "$WATCH_EVENTS" \
            --exclude '/\.git/' \
            "$LOCAL" 2>/dev/null; then
            # File change detected — debounce then sync
            log "Change detected, waiting ${SYNC_DELAY}s..."
            sleep "$SYNC_DELAY"
            bisync && notify ok "Synchronized ($LOCAL)" || { notify fail "Sync failed ($LOCAL)"; log "Sync failed"; }
        else
            exit_code=$?
            if [[ $exit_code -eq 2 ]]; then
                # Timeout — forced interval sync
                log "Interval sync triggered"
                bisync || { notify fail "Interval sync failed ($LOCAL)"; log "Interval sync failed"; }
            else
                log "inotifywait error (exit $exit_code), retrying in 10s..."
                sleep 10
            fi
        fi
    done
    ;;

*)
    echo "Usage: $(basename "$0") <local-path> <remote> [watch|once|resync]"
    exit 1
    ;;
esac
