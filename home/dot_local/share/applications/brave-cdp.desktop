[Desktop Entry]
Version=1.0
Name=Brave (CDP)
GenericName=Web Browser
Comment=Brave with remote debugging enabled on port 9222
StartupNotify=true
StartupWMClass=brave-browser
Exec=/usr/bin/flatpak run --branch=stable --arch=x86_64 --command=brave --file-forwarding com.brave.Browser --remote-debugging-port=9222 @@u %U @@
Terminal=false
Icon=com.brave.Browser
Type=Application
Categories=Network;WebBrowser;
