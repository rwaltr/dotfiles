// Niri config entrypoint — follows Zirconium's layered convention.
// https://yalter.github.io/niri/
// https://danklinux.com/docs/
//
// DO NOT put customizations here — use local.kdl instead.

// DMS integration (colors, binds, layout overlays from DankMaterialShell)
include optional=true "dms.kdl"

// Zirconium system defaults (input, layout, binds, window-rules, etc.)
include optional=true "/usr/share/zirconium/zdots/system/niri/zirconium.kdl"

// User overrides — all personal config goes here
include "local.kdl"
