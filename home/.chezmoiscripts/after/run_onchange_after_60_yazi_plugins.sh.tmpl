#!/usr/bin/env bash
# vi: ft=sh
# Install yazi plugins via ya pkg add (idempotent).
# run_onchange — reruns whenever this script changes.
#
# plugin list hash: {{ "cap153/tv" | sha256sum }}

set -euo pipefail

# Ensure brew + mise are on PATH (ya is installed via mise)
if ! command -v ya &>/dev/null; then
	if [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
		eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
	fi
	if command -v mise &>/dev/null; then
		eval "$(mise activate bash --shims)"
	fi
fi

if ! command -v ya &>/dev/null; then
	echo "WARN: ya (yazi CLI) not found. Skipping plugin install." >&2
	exit 0
fi

echo "Installing yazi plugins and flavors..."
ya pkg add cap153/tv 2>/dev/null || true
ya pkg add yazi-rs/flavors:base16 2>/dev/null || true
